{
  "name": "@prototype/cedar-auth",
  "version": "1.0.0",
  "description": "Cedar-based authorization middleware for Prototype Platform Express services",
  "license": "MIT-0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "require": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    }
  },
  "bin": {
    "cedar-auth-validate": "dist/validate-cli.js"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "@cedar-policy/cedar-wasm": "^4.11.2"
  },
  "peerDependencies": {
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.0",
    "express": "^4.21.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.4",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
